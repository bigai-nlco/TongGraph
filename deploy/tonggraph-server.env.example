# Copy to a private env file, for example /etc/tonggraph/tonggraph-server.env.
# Do not commit real tokens.

TONGGRAPH_ADMIN_TOKEN=change-me-admin-token
TONGGRAPH_ALICE_TOKEN=change-me-alice-token
TONGGRAPH_READER_TOKEN=change-me-reader-token

# Optional script defaults:
# TONGGRAPH_CONFIG=/opt/tonggraph/deploy/tonggraph-server.yml
# TONGGRAPH_BASE_URL=http://127.0.0.1:8719
# TONGGRAPH_SMOKE_GRAPH=smoke_test
# TONGGRAPH_SMOKE_READER=smoke_reader
# TONGGRAPH_SMOKE_READER_TOKEN=change-me-smoke-reader-token
